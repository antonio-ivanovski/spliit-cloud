# Database container settings. Use a long random password in production.
POSTGRES_DB=spliit
POSTGRES_USER=spliit
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# API runtime settings.
WEB_ORIGINS=https://your-cloudflare-pages-domain.pages.dev
PUBLIC_DEFAULT_CURRENCY_CODE=

# Expense document uploads.
PUBLIC_ENABLE_EXPENSE_DOCUMENTS=false
S3_UPLOAD_KEY=
S3_UPLOAD_SECRET=
S3_UPLOAD_BUCKET=spliit-prod-uploads
S3_UPLOAD_REGION=auto
S3_UPLOAD_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_UPLOAD_PUBLIC_URL=https://uploads.spliit.cloud

# Better Auth (required in production: BETTER_AUTH_SECRET).
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.your-domain.com

# Optional: Google OAuth (leave empty to disable).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP (required in production: SMTP_HOST). Used for magic-link auth and
# group sync invitations. Examples:
#   Gmail:     smtp.gmail.com / 587 / your-gmail / app-password
#   SendGrid:  smtp.sendgrid.net / 587 / apikey / your-api-key
#   Mailgun:   smtp.mailgun.org / 587 / postmaster@yourdomain.com / smtp-pass
#   Postmark:  smtp.postmarkapp.com / 587 / server-token / server-token
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Required in production. The "From" header on every outgoing email.
EMAIL_FROM="Spliit <noreply@yourdomain.com>"
