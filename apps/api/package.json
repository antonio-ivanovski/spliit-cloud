{
  "name": "@spliit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./router": "./src/trpc/routers/_app.ts",
    "./app": "./src/app.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/server.ts",
    "start": "bun --env-file=../../.env run src/server.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run --globals src",
    "test:integration": "vitest run --config vitest.integration.config.ts --reporter=verbose"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@hono/node-server": "^1.19.14",
    "@json2csv/plainjs": "^7.0.6",
    "@spliit/db": "workspace:*",
    "@spliit/domain": "workspace:*",
    "@trpc/server": "^11.18.0",
    "better-auth": "^1.6.20",
    "content-disposition": "^0.5.4",
    "hono": "^4.12.26",
    "nanoid": "^5.1.15",
    "nodemailer": "^9.0.1",
    "openai": "^6.45.0",
    "superjson": "^2.2.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@spliit/config": "workspace:*",
    "@types/content-disposition": "^0.5.9",
    "@types/node": "24.13.2",
    "@types/nodemailer": "^8.0.1",
    "nodemailer-mock": "^2.0.13",
    "typescript": "7.0.1-rc",
    "vitest": "5.0.0-beta.5"
  }
}
