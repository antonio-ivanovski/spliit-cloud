{
  "extends": "@spliit/config/tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/routeTree.gen.ts",
    "playwright.config.ts",
    "vite.config.ts",
    "tests/**/*.ts"
  ]
}
