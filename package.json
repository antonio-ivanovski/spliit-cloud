{
  "name": "spliit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts/i18n"
  ],
  "trustedDependencies": [
    "@prisma/adapter-pg",
    "@prisma/client",
    "@prisma/engines",
    "esbuild",
    "prisma"
  ],
  "scripts": {
    "dev": "turbo --ui=tui run dev",
    "build": "turbo --ui=tui run build",
    "start": "bun --filter @spliit/api start",
    "lint": "turbo --ui=tui run lint",
    "check-types": "turbo --ui=tui run check-types",
    "check-formatting": "prettier -c .",
    "prettier": "prettier -w .",
    "prisma-migrate": "bun run --filter @spliit/db prisma-migrate",
    "prisma-generate": "bun run --filter @spliit/db prisma-generate",
    "start-container": "docker compose --env-file container.env up",
    "test": "turbo --ui=tui run test",
    "test:integration": "turbo run test:integration",
    "test-e2e": "bun --filter @spliit/web test-e2e",
    "i18n": "bun scripts/i18n/src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^3.2.4",
    "turbo": "^2.9.18",
    "typescript": "^5.9.3"
  }
}
